PREFIX csor:             <https://data.omgeving.vlaanderen.be/ns/csor#>
PREFIX csor-constraints: <https://data.omgeving.vlaanderen.be/ns/csor-constraints#>
PREFIX dcterms:          <http://purl.org/dc/terms/>
PREFIX iadopt:           <https://w3id.org/iadopt/ont/>
PREFIX owl:              <http://www.w3.org/2002/07/owl#>
PREFIX qudt:             <http://qudt.org/schema/qudt/>
PREFIX rdf:              <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:             <http://www.w3.org/2000/01/rdf-schema#>
PREFIX sh:               <http://www.w3.org/ns/shacl#>
PREFIX skos:             <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd:              <http://www.w3.org/2001/XMLSchema#>

[ rdf:type     sh:ValidationReport;
  sh:conforms  false;
  sh:result    [ rdf:type                      sh:ValidationResult;
                 sh:focusNode                  <https://data.omgeving.vlaanderen.be/id/concept/csor/natuurkundigedimensie/ND_44>;
                 sh:resultMessage              "Er moet exact 1 symbool zijn";
                 sh:resultPath                 csor:symbool;
                 sh:resultSeverity             sh:Violation;
                 sh:sourceConstraintComponent  sh:MinCountConstraintComponent;
                 sh:sourceShape                csor-constraints:symbool
               ];
  sh:result    [ rdf:type                      sh:ValidationResult;
                 sh:focusNode                  <https://data.omgeving.vlaanderen.be/id/concept/csor/natuurkundigedimensie/ND_44>;
                 sh:resultMessage              "Er moet exact 1 Notation zijn";
                 sh:resultPath                 skos:notation;
                 sh:resultSeverity             sh:Violation;
                 sh:sourceConstraintComponent  sh:MinCountConstraintComponent;
                 sh:sourceShape                csor-constraints:notation
               ]
] .
